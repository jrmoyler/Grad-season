{
  "name": "grad-season-ad-video",
  "version": "1.0.0",
  "description": "Grad Season advertisement video built with Remotion",
  "private": true,
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render GradSeasonAd out/grad-season-ad.mp4",
    "render": "remotion render GradSeasonAd out/grad-season-ad.mp4 --log=verbose",
    "render:local": "remotion render GradSeasonAd out/grad-season-ad.mp4 --browser-executable=/root/.cache/ms-playwright/chromium_headless_shell-1194/chrome-linux/headless_shell"
  },
  "dependencies": {
    "@remotion/cli": "4.0.290",
    "remotion": "4.0.290"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "remotion": {
    "entryPoint": "src/index.tsx"
  }
}
