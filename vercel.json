{
  "version": 2,
  "name": "grad-season",
  "public": true,
  "routes": [
    {
      "src": "/order",
      "dest": "/order.html"
    },
    {
      "src": "/production",
      "dest": "/production.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
